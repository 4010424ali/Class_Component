# Environment Variables — DO NOT commit real values
# Copy this file to .env and fill in your secrets

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/auth_db

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:3000
